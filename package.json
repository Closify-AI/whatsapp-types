{
  "author": "Rodrigo de Souza",
  "bugs": {
    "url": "https://github.com/Closify-AI/whatsapp-types/issues"
  },
  "dependencies": {
    "@types/node": "^25.6.0",
    "zod": "^4.3.6"
  },
  "description": "WhatsApp Business types for NodeJS",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typeconv": "^2.3.1",
    "typescript": "^6.0.3"
  },
  "homepage": "https://github.com/Closify-AI/whatsapp-types#readme",
  "keywords": [
    "WhatsApp",
    "SDK",
    "Business",
    "Platform",
    "types",
    "NodeJS",
    "Cloud API"
  ],
  "license": "MIT",
  "main": "index.js",
  "name": "@closify-ai/whatsapp-business-types",
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com/",
    "tag": "latest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Closify-AI/whatsapp-types.git"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist --clean",
    "build-openapi": "typeconv -f ts -t oapi -o dist/openapi src/**/*.ts",
    "ci-only": "find . -maxdepth 1 -type f -exec cp -t ./dist {} +",
    "test": "echo \"Error: no test specified\" && exit 0"
  },
  "type": "module",
  "types": "index.d.ts",
  "version": "1.0.0-beta.6"
}
